{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:debug",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-tags",
        "dev",
        "-gcflags",
        "all=-N -l",
        "-ldflags=-extldflags \"-framework UniformTypeIdentifiers\"",
        "-o",
        "${workspaceFolder}/build/bin/debug_app"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    }
  ]
}